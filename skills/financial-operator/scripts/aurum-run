#!/usr/bin/env bash
# Aurum — ponto de entrada único para scripts (caminho absoluto, HERMES_HOME do perfil).
# Uso: aurum-run hint "listar contas"
#      aurum-run do list-accounts
#      aurum-run report monthly --month 2026-06
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROFILE="$(cd "$HERE/../../.." && pwd)"
export HERMES_HOME="${HERMES_HOME:-$PROFILE}"

_unknown() {
  local cmd="$1"
  python3 -c "import json,sys; print(json.dumps({'status':'error','message':f'Comando aurum-run desconhecido: {sys.argv[1]}','suggestion':'aurum-run hint \"listar contas\"','help':'aurum-run help --json'}, ensure_ascii=False))" "$cmd" >&2
  exit 1
}

cmd="${1:?uso: aurum-run hint|help|do|report|ledger|accounts|state|backup}"
shift

case "$cmd" in
  hint)
    exec python3 "$HERE/do.py" hint "$@"
    ;;
  help)
    exec python3 "$HERE/do.py" help "$@"
    ;;
  menu)
    exec python3 "$HERE/do.py" menu
    ;;
  do)
    exec python3 "$HERE/do.py" run "$@"
    ;;
  report|reports)
    exec python3 "$HERE/reports.py" "$@"
    ;;
  ledger)
    exec python3 "$HERE/ledger.py" "$@"
    ;;
  accounts|categories|check|repair|reset|list|init)
    exec python3 "$HERE/ledger.py" "$cmd" "$@"
    ;;
  append)
    exec python3 "$HERE/ledger.py" append "$@"
    ;;
  state|rebuild|rebuild_state)
    exec python3 "$HERE/rebuild_state.py" "$@"
    ;;
  backup)
    exec python3 "$HERE/backup.py" "$@"
    ;;
  *)
    _unknown "$cmd"
    ;;
esac
